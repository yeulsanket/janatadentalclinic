# ═══ JANATA DENTAL SUITE — ENVIRONMENT VARIABLES (.env) ═══
# Copy this file to '.env' and insert your actual API keys.
# Note: Because this is a Vite React app, all client-side environment keys MUST start with 'VITE_'

# 1. Groq AI API Key (Required for 24/7 AI Patient Assistant / SmileBot in Chatbot.jsx)
# Get a free API key at: https://console.groq.com/keys
VITE_GROQ_API_KEY="gsk_your_groq_api_key_here"

# 2. EmailJS Configuration (Required for Appointment Form & Chatbot Lead Emails)
# Create a free account at: https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID="service_xxxxxxx"
VITE_EMAILJS_TEMPLATE_ID="template_xxxxxxx"
VITE_EMAILJS_PUBLIC_KEY="xxxxxxxxxxxxxxxxx"
